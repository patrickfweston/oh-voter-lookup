# Ohio SOS browser cookie for scripts/download-ohio-counties.mjs (optional)
# OH_SOS_COOKIE=

# PostgreSQL (required for the API).
# Local Postgres default port:
DATABASE_URL=postgresql://voter:voter@127.0.0.1:5432/voter_guide
# If the DB is only the docker-compose `db` service (host port 5492 → container 5432), use:
# DATABASE_URL=postgresql://voter:voter@127.0.0.1:5492/voter_guide

# Public URL (optional): https://ohvoter.patrickfweston.com via Cloudflare Tunnel → origin
#   docker: tunnel service URL = host:port where nginx listens (8092). Same machine as cloudflared: 127.0.0.1; if cloudflared runs elsewhere, use that host’s LAN IP, e.g. http://192.168.x.x:8092 (cloudflared.example.yml).
#   dev: tunnel at http://127.0.0.1:5173; add extra hosts with env if needed:
#   __VITE_ADDITIONAL_SERVER_ALLOWED_HOSTS=other.example.com
#
# Docker (full stack: db + api + nginx UI):
#   npm run docker:up    → UI at http://127.0.0.1:8092  (nginx proxies /api to the API on 3092 in the api container)
#   npm run docker:down  → stop and remove web, api, and db containers (volumes kept)
# Postgres only for local dev:
#   npm run db:up
#   npm run db:down      → stop the db container only
# Import from the host: set DATABASE_URL to the published port (5432 local Postgres, or 5492 for Compose db), then npm run db:import

# Optional: override data directory glob for npm run db:import
# VOTER_DATA_GLOB=data/*.txt
