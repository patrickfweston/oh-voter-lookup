# Ohio SOS browser cookie for scripts/download-ohio-counties.mjs (optional)
# OH_SOS_COOKIE=

# PostgreSQL (required for the API). Example matches docker-compose.yml defaults.
DATABASE_URL=postgresql://voter:voter@127.0.0.1:5432/voter_guide

# Docker (full stack: db + api + nginx UI):
#   npm run docker:up  → app at http://127.0.0.1:8080  (/api proxied to the api container)
# Postgres only for local dev:
#   npm run db:up
# Import from the host (db port published): keep DATABASE_URL pointing at 127.0.0.1:5432, then npm run db:import

# Optional: override data directory glob for npm run db:import
# VOTER_DATA_GLOB=data/*.txt
